# Comma-separated list of origins allowed to connect via CORS and WebSocket
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# SQLite by default for local dev; swap for a Postgres URL in production
DATABASE_URL=sqlite:///./ticker.db

# Local uvicorn bind (Render supplies its own PORT at runtime)
HOST=0.0.0.0
PORT=8000
